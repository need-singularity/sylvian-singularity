{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .shared/hooks/nexus6-pre-commit.sh",
            "timeout": 15,
            "statusMessage": "🔭 NEXUS-6 커밋 스캔"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .shared/hooks/nexus6-universal.sh",
            "timeout": 10,
            "statusMessage": "🔭 NEXUS-6 에이전트 컨텍스트"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .shared/hooks/nexus6-post-edit.sh",
            "timeout": 10,
            "statusMessage": "🔭 NEXUS-6 수치 검증"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .shared/hooks/nexus6-post-bash.sh",
            "timeout": 15,
            "statusMessage": "🔭 NEXUS-6 실행 결과 스캔"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .shared/hooks/growth-scan.sh",
            "timeout": 10,
            "statusMessage": "🔭 NEXUS-6 성장 스캔"
          }
        ]
      }
    ]
  }
}