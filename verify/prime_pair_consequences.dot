digraph consequences {
    rankdir=TB;
    node [shape=box, style=rounded, fontsize=10];
    edge [fontsize=8];

    A [label="A: (p-1)(q-1) = 2", fillcolor="gold", style="rounded,filled"];
    B [label="B: {p,q} = {2,3} (unique solution)", fillcolor="white", style="rounded,filled"];
    C [label="C: p*q = 6", fillcolor="white", style="rounded,filled"];
    D [label="D: 6 is semiprime", fillcolor="white", style="rounded,filled"];
    E [label="E: gcd(2,3) = 1", fillcolor="white", style="rounded,filled"];
    F [label="F: phi(6) = (2-1)(3-1) = 2", fillcolor="white", style="rounded,filled"];
    G [label="G: sigma(6) = (1+2)(1+3) = 12 = 2*6", fillcolor="white", style="rounded,filled"];
    H [label="H: 6 is perfect number", fillcolor="lightgreen", style="rounded,filled"];
    I [label="I: sigma_{-1}(6) = 2", fillcolor="lightblue", style="rounded,filled"];
    J [label="J: Z/2Z x Z/3Z = Z/6Z (CRT)", fillcolor="white", style="rounded,filled"];
    K [label="K: 6/((2-1)(3-1)) = 3 (integer, Euler product)", fillcolor="white", style="rounded,filled"];
    L [label="L: 1/2 + 1/3 + 1/6 = 1 (unit fraction)", fillcolor="white", style="rounded,filled"];
    M [label="M: 6 is smallest perfect number", fillcolor="white", style="rounded,filled"];
    N [label="N: 6 = 1+2+3 (triangular)", fillcolor="white", style="rounded,filled"];
    O [label="O: 6 = 1*2*3 (primorial)", fillcolor="white", style="rounded,filled"];
    P [label="P: Bootstrap: sigma_{-1}(6)=2 -> {2,3} -> 6 -> sigma_{-1}(6)=2", fillcolor="lightyellow", style="rounded,filled"];
    Q [label="Q: Euler product p=2,3 truncation = 3", fillcolor="white", style="rounded,filled"];
    R [label="R: 2 is prime (sigma_{-1} output)", fillcolor="white", style="rounded,filled"];
    S [label="S: Only semiprime perfect number", fillcolor="lightgreen", style="rounded,filled"];
    T [label="T: phi(6) = sigma_{-1}(6) = 2 (self-duality)", fillcolor="lightyellow", style="rounded,filled"];

    A -> B [label="factor (p-1)(q-1)=1*2"];
    B -> C [label="multiply"];
    C -> D [label="definition"];
    B -> E [label="distinct primes"];
    B -> F [label="Euler totient"];
    B -> G [label="sigma multiplicative"];
    G -> H [label="sigma(n)=2n"];
    H -> I [label="divide by n"];
    E -> J [label="CRT"];
    B -> K [label="compute ratio"];
    B -> L [label="partial fractions of 1/6"];
    C -> N [label="1+2+3"];
    C -> O [label="1*2*3"];
    I -> R [label="2 is prime", color=red, penwidth=2];
    R -> B [label="factor 6 = 2*3", color=red, penwidth=2];
    I -> P [label="cycle entry", color=red, penwidth=2];
    B -> P [label="cycle body", color=red, penwidth=2];
    H -> S [label="Theorem 2"];
    D -> S [label="semiprime + perfect"];
    F -> T [label="phi = sigma_{-1}"];
    I -> T [label="sigma_{-1} = phi"];
    H -> M [label="smallest"];
    K -> Q [label="Euler product interpretation"];
}